# StubHub EDC Shuttle Monitor — Environment Variables
# Copy this file to .env and fill in the required values before running.
# On Railway, set these in the Railway dashboard (Variables tab) — do NOT commit .env.

# ---------------------------------------------------------------------------
# StubHub
# ---------------------------------------------------------------------------

# Pre-filtered listing URL (optional — a sensible default is hardcoded)
# The URL below narrows results to Mid-Strip Premier Shuttle tickets.
# STUBHUB_URL=https://www.stubhub.com/electric-daisy-carnival-las-vegas-tickets-5-15-2026/event/160232237/?quantity=2&sections=1747871%2C2037648%2C2037647%2C2037641%2C2037642%2C2037643%2C2037640&ticketClasses=14450&rows=&seats=&seatTypes=&listingQty=

# Maximum price per ticket to alert on (default: 500)
MAX_PRICE_PER_TICKET=500

# ---------------------------------------------------------------------------
# Resend email API  (REQUIRED)
# ---------------------------------------------------------------------------

# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Verified sender address — must be from a domain you've verified in Resend
# https://resend.com/domains
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------

# Recipient email(s) — comma-separated for multiple (optional — defaults to GMAIL_ADDRESS)
NOTIFICATION_EMAIL=you@gmail.com,friend@example.com

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Path to SQLite file for persisting seen listings (default: seen_listings.db)
# NOTE: Railway's filesystem is ephemeral — the DB resets on redeploy/restart.
# The bot will re-alert on listings that still match after a restart; this is
# acceptable for the monitoring use case. Use a Railway Volume for persistence.
DB_PATH=seen_listings.db

# ---------------------------------------------------------------------------
# Scheduling
# ---------------------------------------------------------------------------

# Quiet hours in US/Pacific — bot polls every 25–35 min during this window
# instead of the normal interval. Accepts "HH:MM" or plain integer hour (0–23).
QUIET_HOURS_START=2
QUIET_HOURS_END=9

# Base polling interval in minutes (default: 5)
CHECK_INTERVAL_MINUTES=5

# Date on which the bot auto-exits (ISO format, default: 2026-05-15)
STOP_DATE=2026-05-15

# ---------------------------------------------------------------------------
# Browser
# ---------------------------------------------------------------------------

# Set to "false" to run Chromium in headed mode (local debugging only)
HEADLESS=true
